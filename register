<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - Chama OS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link rel="icon" href="images/chama-icon.png">
</head>
<body class="bg-gray-50 min-h-screen">
    <-pn Header -->
    <header class="bg-white shadow-sm border-b">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center py-4">
                <div class="flex items-center">
                    <a href="index.html" class="text-2xl font-bold text-gray-900">Chama OS</a>
                </div>
                <nav class="hidden md:flex space-x-8">
                    <a href="index.html" class="text-gray-600 hover:text-green-600">Home</a>
                    <a href="features" class="text-gray-600 hover:text-green-600">Features</a>
                    <a href="pricing" class="text-gray-600 hover:text-green-600">Pricing</a>
                    <a href="about" class="text-gray-600 hover:text-green-600">About</a>
                    <a href="register" class="text-green-600 font-semibold">Register</a>
                </nav>
            </div>
        </div>
    </header>

    <-pn Main Content -->
    <main class="max-w-md mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <-pn Registration Form -->
        <div class="bg-white p-8 rounded-lg shadow-sm border">
            <div class="text-center mb-8">
                <h1 class="text-3xl font-bold mb-2">Create Your Account</h1>
                <p class="text-gray-600">Join thousands of chamas using Chama OS</p>
            </div>

            <form class="space-y-6">
                <-pn Personal Information -->
                <div class="space-y-4">
                    <h2 class="text-lg font-semibold text-gray-900">Personal Information</h2>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Full Name</label>
                        <input type="text" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent" placeholder="Enter your full name">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Email Address</label>
                        <input type="email" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent" placeholder="your@email.com">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Phone Number</label>
                        <input type="tel" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent" placeholder="+254 XXX XXX XXX">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">ID Number</label>
                        <input type="text" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent" placeholder="Enter your ID number">
                    </div>
                </div>

                <-pn Account Security -->
                <div class="space-y-4">
                    <h2 class="text-lg font-semibold text-gray-900">Account Security</h2>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Password</label>
                        <input type="password" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent" placeholder="Create a strong password">
                        <p class="text-xs text-gray-500 mt-1">Must be at least 8 characters with numbers and symbols</p>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Confirm Password</label>
                        <input type="password" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent" placeholder="Confirm your password">
                    </div>
                </div>

                <-pn Terms and Conditions -->
                <div class="space-y-4">
                    <div class="flex items-start">
                        <input type="checkbox" required class="mt-1 h-4 w-4 text-green-600 focus:ring-green-500 border-gray-300 rounded">
                        <label class="ml-2 block text-sm text-gray-700">
                            I agree to the <a href="terms" class="text-green-600 hover:text-green-700">Terms of Service</a> and <a href="privacy" class="text-green-600 hover:text-green-700">Privacy Policy</a>
                        </label>
                    </div>

                    <div class="flex items-start">
                        <input type="checkbox" class="mt-1 h-4 w-4 text-green-600 focus:ring-green-500 border-gray-300 rounded">
                        <label class="ml-2 block text-sm text-gray-700">
                            I would like to receive updates and newsletters from Chama OS
                        </label>
                    </div>
                </div>

                <-pn Submit Button -->
                <button type="submit" class="w-full bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition-colors font-semibold text-lg">
                    Create Account
                </button>
            </form>

            <-pn Login Link -->
            <div class="mt-6 text-center">
                <p class="text-gray-600">
                    Already have an account?
                    <a href="auth/verify" class="text-green-600 hover:text-green-700 font-semibold">Sign in here</a>
                </p>
            </div>
        </div>

        <-pn Benefits Section -->
        <div class="mt-8 bg-green-50 rounded-lg p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Why Register with Chama OS?</h3>
            <div class="space-y-3">
                <div class="flex items-center">
                    <i class="fas fa-check text-green-500 mr-3"></i>
                    <span class="text-sm text-gray-700">Free 14-day trial - no credit card required</span>
                </div>
                <div class="flex items-center">
                    <i class="fas fa-check text-green-500 mr-3"></i>
                    <span class="text-sm text-gray-700">Secure and compliant with Kenyan regulations</span>
                </div>
                <div class="flex items-center">
                    <i class="fas fa-check text-green-500 mr-3"></i>
                    <span class="text-sm text-gray-700">24/7 support and training resources</span>
                </div>
                <div class="flex items-center">
                    <i class="fas fa-check text-green-500 mr-3"></i>
                    <span class="text-sm text-gray-700">Mobile-friendly platform</span>
                </div>
            </div>
        </div>

        <-pn Support Section -->
        <div class="mt-6 text-center">
            <p class="text-sm text-gray-600">
                Need help? Contact our support team at
                <a href="mailto:support@chamaos.com" class="text-green-600 hover:text-green-700">support@chamaos.com</a>
            </p>
        </div>
    </main>

    <-pn Footer -->
    <footer class="bg-gray-800 text-white py-8 mt-16">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center text-sm text-gray-300">
                <p>&copy; 2025 Chama OS. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script>
        // Form validation
        document.querySelector('form').addEventListener('submit', function(e) {
            e.preventDefault();

            const password = document.querySelector('input[type="password"]').value;
            const confirmPassword = document.querySelectorAll('input[type="password"]')[1].value;

            if (password !== confirmPassword) {
                alert('Passwords do not match. Please try again.');
                return;
            }

            if (password.length < 8) {
                alert('Password must be at least 8 characters long.');
                return;
            }

            // Here you would typically send the form data to your server
            alert('Account created successfully! Please check your email for verification.');
        });
    </script>
</body>
</html>
