<body class="bg-gray-50 min-h-screen">
    <-pn Header -->
    <header class="bg-white shadow-sm border-b">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center py-4">
                <div class="flex items-center">
                    <a href="index.html" class="text-2xl font-bold text-gray-900">Chama OS</a>
                </div>
                <nav class="hidden md:flex space-x-8">
                    <a href="index.html" class="text-gray-600 hover:text-green-600">Home</a>
                    <a href="features" class="text-gray-600 hover:text-green-600">Features</a>
                    <a href="pricing" class="text-gray-600 hover:text-green-600">Pricing</a>
                    <a href="about" class="text-gray-600 hover:text-green-600">About</a>
