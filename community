    <-pn Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <-pn Hero Section -->
        <div class="text-center mb-16">
            <h1 class="text-4xl md:text-5xl font-bold mb-6">Join Our Community</h1>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto">Connect with thousands of chama members across Kenya. Share experiences, get advice, and grow together.</p>
        </div>

        <-pn Community Stats -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-16">
            <div class="bg-white p-6 rounded-lg shadow-sm border text-center">
                <div class="text-3xl font-bold text-green-600 mb-2">50K+</div>
                <div class="text-gray-600">Active Members</div>
            </div>
            <div class="bg-white p-6 rounded-lg shadow-sm border text-center">
                <div class="text-3xl font-bold text-blue-600 mb-2">10K+</div>
                <div class="text-gray-600">Chamas Created</div>
            </div>
            <div class="bg-white p-6 rounded-lg shadow-sm border text-center">
                <div class="text-3xl font-bold text-purple-600 mb-2">500M+</div>
                <div class="text-gray-600">KES Managed</div>
            </div>
            <div class="bg-white p-6 rounded-lg shadow-sm border text-center">
                <div class="text-3xl font-bold text-orange-600 mb-2">98%</div>
                <div class="text-gray-600">Satisfaction Rate</div>
            </div>
        </div>

        <-pn Community Features -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-16">
            <-pn Discussion Forums -->
            <div class="bg-white p-8 rounded-lg shadow-sm border">
                <div class="flex items-center mb-6">
                    <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mr-4">
                        <i class="fas fa-comments text-blue-600 text-xl"></i>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold">Discussion Forums</h3>
                        <p class="text-gray-600">Connect with other chama members</p>
                    </div>
                </div>
                <p class="text-gray-600 mb-6">Share experiences, ask questions, and learn from successful chamas across Kenya. Our moderated forums cover topics from investment strategies to member management.</p>
                <div class="space-y-3">
                    <div class="flex items-center text-sm text-gray-600">
                        <i class="fas fa-check text-green-500 mr-2"></i>
                        Investment strategies
                    </div>
                    <div class="flex items-center text-sm text-gray-600">
                        <i class="fas fa-check text-green-500 mr-2"></i>
                        Member recruitment tips
                    </div>
                    <div class="flex items-center text-sm text-gray-600">
                        <i class="fas fa-check text-green-500 mr-2"></i>
                        Loan management advice
                    </div>
                </div>
            </div>

            <-pn Success Stories -->
            <div class="bg-white p-8 rounded-lg shadow-sm border">
                <div class="flex items-center mb-6">
                    <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mr-4">
                        <i class="fas fa-trophy text-green-600 text-xl"></i>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold">Success Stories</h3>
                        <p class="text-gray-600">Learn from successful chamas</p>
                    </div>
                </div>
                <p class="text-gray-600 mb-6">Read inspiring stories from chamas that have achieved remarkable growth and success. Get insights into what works and how they did it.</p>
                <div class="space-y-3">
                    <div class="flex items-center text-sm text-gray-600">
                        <i class="fas fa-star text-yellow-500 mr-2"></i>
                        Real case studies
                    </div>
                    <div class="flex items-center text-sm text-gray-600">
                        <i class="fas fa-star text-yellow-500 mr-2"></i>
                        Growth strategies
                    </div>
                    <div class="flex items-center text-sm text-gray-600">
                        <i class="fas fa-star text-yellow-500 mr-2"></i>
                        Best practices
                    </div>
                </div>
            </div>
        </div>

